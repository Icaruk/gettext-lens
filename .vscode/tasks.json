{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "label": "npm: watch",
      "isBackground": true,
      "problemMatcher": {
        "owner": "esbuild",
        "background": {
          "activeOnStart": true,
          "beginsPattern": "esbuild",
          "endsPattern": "build finished|Watching for changes|Build complete|Done in"
        },
        "pattern": {
          "regexp": "^(.+):(\\d+):(\\d+):\\s*(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 4
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
